<Window x:Class="InteriorCatalog.CatalogWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Catalog"
Height="600"
Width="900"
Background="#1A1A2E"
WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <SolidColorBrush x:Key="PrimaryColor" Color="#6C63FF"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#FF6584"/>
        <SolidColorBrush x:Key="CardBg" Color="#0F3460"/>
        <SolidColorBrush x:Key="TextLight" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="TextDim" Color="#A0A0C0"/>
        <SolidColorBrush x:Key="HeaderBg" Color="#16213E"/>

        <!-- Кнопки сортировки -->
        <Style TargetType="Button" x:Key="SortButton">
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#5A52D9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#313c48"/>
                    <Setter Property="Foreground" Value="#888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Group button -->
        <Style TargetType="Button" x:Key="GroupButton">
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF7B99"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0A0F1F"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="RowBackground" Value="#0A0F1F"/>
            <Setter Property="AlternatingRowBackground" Value="#0F1525"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
        </Style>

    </Window.Resources>

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="📋 Каталог мебели"
FontSize="22"
FontWeight="Bold"
Foreground="{StaticResource TextLight}"
Margin="0,0,0,10"/>

        <!-- Панель сортировки -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Левая часть: сортировка -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Артикул ↑" Style="{StaticResource SortButton}" Click="SortArticleAsc_Click"/>
                <Button Content="Артикул ↓" Style="{StaticResource SortButton}" Margin="5,0" Click="SortArticleDesc_Click"/>

                <Button Content="Имя ↑" Style="{StaticResource SortButton}" Click="SortNameAsc_Click"/>
                <Button Content="Имя ↓" Style="{StaticResource SortButton}" Margin="5,0" Click="SortNameDesc_Click"/>

                <Button Content="Цена ↑" Style="{StaticResource SortButton}" Click="SortPriceAsc_Click"/>
                <Button Content="Цена ↓" Style="{StaticResource SortButton}" Margin="5,0" Click="SortPriceDesc_Click"/>

                <Button Content="Сгруппировать"
                Style="{StaticResource GroupButton}"
                Margin="10,0,0,0"
                Click="PrioritySort_Click"/>
            </StackPanel>

            <!-- Правая часть: кнопки -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="UndoButton"
                    Content="Вернуть товар"
                        Style="{StaticResource SortButton}"
                        Click="UndoRemove_Click"
                        IsEnabled="False"
                        Margin="10,0,0,0"/>

                <Button Content="Удалить товар"
                Style="{StaticResource SortButton}"
                Click="RemoveButton_Click"
                Width="120"
                Margin="10,0,0,0"/>
            </StackPanel>

        </Grid>

        <!-- Фильтр -->
        <ComboBox x:Name="TypeFilterComboBox"
Grid.Row="2"
Width="160"
Margin="0,0,0,10"
SelectionChanged="TypeFilterComboBox_SelectionChanged">
            <ComboBoxItem Content="All"/>
            <ComboBoxItem Content="Chair"/>
            <ComboBoxItem Content="Sofa"/>
            <ComboBoxItem Content="Table"/>
            <ComboBoxItem Content="Bed"/>
            <ComboBoxItem Content="Stool"/>
            <ComboBoxItem Content="Armchair"/>
        </ComboBox>

        <!-- Таблица -->
        <DataGrid x:Name="FurnitureGrid"
Grid.Row="3"
AutoGenerateColumns="False"
IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="*"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="*"/>
                <DataGridTextColumn Header="Бренд" Binding="{Binding Brand}" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="*"/>

                <DataGridTemplateColumn Header="Изображение">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Открыть"
Click="OpenImage_Click"
Background="{StaticResource PrimaryColor}"
Foreground="White"
BorderThickness="0"
Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="4"
                Background="{StaticResource HeaderBg}"
                Padding="10">
            <Grid>
                <TextBlock x:Name="TotalPriceText"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Text="Итого 0 ₽"/>
            </Grid>
        </Border>
                
   
        

    </Grid>
</Window>