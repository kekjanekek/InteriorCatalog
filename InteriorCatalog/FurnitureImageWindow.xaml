<Window x:Class="InteriorCatalog.FurnitureImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InteriorCatalog"
        mc:Ignorable="d"
        Title="Просмотр изображения" 
        Height="550" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        MinHeight="400"
        MinWidth="500">

    <Window.Resources>
        <!-- Цветовая палитра (как в MainWindow) -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#6C63FF"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#FF6584"/>
        <SolidColorBrush x:Key="CardBg" Color="#0F3460"/>
        <SolidColorBrush x:Key="TextLight" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="TextDim" Color="#A0A0C0"/>
    </Window.Resources>

    <Grid>
        <!-- Фоновый градиент -->
        <Grid.Background>
            <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                <GradientStop Color="#1A1A2E" Offset="0"/>
                <GradientStop Color="#16213E" Offset="0.5"/>
                <GradientStop Color="#0F3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Декоративные круги -->
        <Ellipse Width="300" Height="300" Fill="#6C63FF" Opacity="0.08" Margin="-100,-80,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Ellipse Width="200" Height="200" Fill="#FF6584" Opacity="0.06" Margin="0,0,-80,0" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

        <!-- Затемнённый фон для контраста -->
        <Border Background="#0A0F1F" Opacity="0.7"/>

        
        <!-- Заголовок окна -->
        <TextBlock Text="🖼️ Просмотр изображения"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextLight}"
                   Margin="20,18,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Opacity="0.9"/>

        <!-- Рамка для изображения -->
        <Border Margin="43"
                Background="#0A0F1F"
                CornerRadius="16"
                BorderBrush="{StaticResource PrimaryColor}"
                BorderThickness="1"
                Padding="10">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.4" Color="#000000"/>
            </Border.Effect>

            <Image x:Name="FurnitureImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <!-- Информационная панель внизу -->
        <Border Background="#0A0F1F"
                CornerRadius="10"
                Padding="12,8"
                Margin="30,0,30,20"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                BorderBrush="{StaticResource CardBg}"
                BorderThickness="1">
            <TextBlock x:Name="FurnitureNameText"
                      Foreground="White"
                      FontSize="16"
                      TextAlignment="Center"/>
        </Border>
    </Grid>
</Window>